{
  "annotations": {"list": []},
  "description": "SCM Platform Inventory Health Dashboard",
  "editable": true,
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds",
            "fixedColor": "red"
          },
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "title": "Low Stock Alerts",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(scm_inventory_low_stock_count)",
          "legendFormat": "Alerts"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "title": "Stockout Count",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(scm_inventory_stockout_count)",
          "legendFormat": "Stockouts"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.8}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "title": "Inventory Turnover Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(scm_inventory_turnover_rate)",
          "legendFormat": "Turnover"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "id": 4,
      "title": "Inventory Levels (24h)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(scm_inventory_total_quantity)",
          "legendFormat": "Total Stock"
        },
        {
          "expr": "sum(scm_inventory_reserved_quantity)",
          "legendFormat": "Reserved"
        },
        {
          "expr": "sum(scm_inventory_available_quantity)",
          "legendFormat": "Available"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["scm", "inventory"],
  "time": {"from": "now-24h", "to": "now"},
  "uid": "scm-inventory-health",
  "version": 1
}
