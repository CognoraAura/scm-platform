# =============================================================================
# SCM Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=changeme

# Master/Slave hosts (Enterprise: read-write separation)
DB_MASTER_HOST=localhost
DB_SLAVE1_HOST=localhost
DB_SLAVE2_HOST=localhost

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Nacos (Service Discovery & Config Center)
# -----------------------------------------------------------------------------
NACOS_SERVER=localhost:8848
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_SERVERS=localhost:9092

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=changeme

# -----------------------------------------------------------------------------
# XXL-Job (Distributed Job Scheduler)
# -----------------------------------------------------------------------------
XXL_JOB_ADMIN=http://localhost:8088/xxl-job-admin
XXL_JOB_ACCESS_TOKEN=default_token

# -----------------------------------------------------------------------------
# Sentinel Dashboard
# -----------------------------------------------------------------------------
SENTINEL_DASHBOARD=localhost:8858

# -----------------------------------------------------------------------------
# Gateway Security
# -----------------------------------------------------------------------------
# API Signature secrets (per application, min 32 characters)
API_SECRET_WEB_APP=
API_SECRET_INTERNAL_SERVICE=

# Identity token signing secret
IDENTITY_SIGNATURE_SECRET=

# mTLS keystore/truststore
KEYSTORE_PATH=classpath:certs/gateway-keystore.p12
KEYSTORE_PASSWORD=
TRUSTSTORE_PATH=classpath:certs/truststore.p12
TRUSTSTORE_PASSWORD=

# -----------------------------------------------------------------------------
# Auth Service
# -----------------------------------------------------------------------------
# SSL/TLS keystore
AUTH_KEYSTORE_PASSWORD=changeit
AUTH_TRUSTSTORE_PASSWORD=changeit

# -----------------------------------------------------------------------------
# Mail (Notification Service)
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=dev
RW_ENABLED=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
CQRS_LOG_LEVEL=INFO
SQL_LOG_LEVEL=INFO
